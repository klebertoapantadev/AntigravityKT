                                                     }
                                     },
                      "id":  "webhook-01",
                      "name":  "Webhook GET",
                      "type":  "n8n-nodes-base.webhook",
                      "typeVersion":  1,
                      "position":  [
                                       100,
                                       200
                                   ],
                      "webhookId":  "66b24917-b5a6-4dd7-a782-067b28cea861"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "// Obtener el parametro fileName del query string\nconst query = $input.item.json.query || {};\nconst fileName = query.fileName || \u0027\u0027;\nreturn { fileName, solicitadoArchivo: fileName !== \u0027\u0027 };"
                                     },
                      "id":  "code-parse",
                      "name":  "Parsear Parametros",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       350,
                                       200
                                   ]
                  },
                  {
                      "parameters":  {
                                         "conditions":  {
                                                            "string":  [
                                                                           {
                                                                               "value1":  "={{ $json.fileName }}",
                                                                               "operation":  "isNotEmpty"
                                                                           }
                                                                       ]
                                                        }
                                     },
                      "id":  "if-01",
                      "name":  "Verificar Nombre Archivo",
                      "type":  "n8n-nodes-base.if",
                      "typeVersion":  1,
                      "position":  [
                                       600,
                                       200
                                   ]
                  },
                  {
                      "parameters":  {
                                                                                  "command":  "stat -c \"%n|%w|%y\" /opt/RAG/implementacion_SARA/*"
                                     },
                      "id":  "cmd-list",
                      "name":  "Listar Archivos del Servidor",
                      "type":  "n8n-nodes-base.executeCommand",
                      "typeVersion":  1,
                      "position":  [
                                       850,
                                       350
                                   ]
                  },
                  {
                      "parameters":  {
                                                                                  "jsCode":  "const stdout = $input.item.json.stdout || '';\nconst lines = stdout.split('\\n').filter(line => line.trim());\n\nconst archivos = lines.map(line => {\n  const [fullPath, birth, mod] = line.split('|');\n  const name = fullPath.split('/').pop();\n  \n  // Limpiar fechas de Linux (quitar milisegundos y timezone si es necesario)\n  const cleanDate = (d) => (d === '-' || !d) ? 'N/A' : d.split('.')[0];\n\n  return {\n    nombre: name,\n    creacion: cleanDate(birth),\n    modificacion: cleanDate(mod)\n  };\n});\n\nreturn { archivos, total: archivos.length, directorio: '/opt/RAG/implementacion_SARA/' };"
                                     },
                      "id":  "code-list",
                      "name":  "Formatear Lista",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1100,
                                       350
                                   ]
                  },
                  {
                      "parameters":  {
                                         "command":  "=cat \"/opt/RAG/implementacion_SARA/{{ $json.fileName }}\" | base64 -w 0"
                                     },
                      "id":  "cmd-read",
                      "name":  "Leer Archivo en Base64",
                      "type":  "n8n-nodes-base.executeCommand",
                      "typeVersion":  1,
                      "position":  [
                                       850,
                                       80
                                   ],
                      "onError":  "continueErrorOutput"
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const resultado = $input.item.json;\nconst stdout = (resultado.stdout || \u0027\u0027).trim();\nconst exitCode = resultado.exitCode;\n\nif (exitCode !== 0 || !stdout) {\n  return { \n    error: true, \n    mensaje: \u0027Archivo no encontrado o error al leerlo\u0027,\n    detalles: resultado.stderr || \u0027Verifica el nombre del archivo\u0027\n  };\n}\n\n// Decodificar el base64 de vuelta al texto original\nconst contenido = Buffer.from(stdout, \u0027base64\u0027).toString(\u0027utf-8\u0027);\nreturn { contenido, archivoLeido: true, bytes: contenido.length };"
                                     },
                      "id":  "code-read",
                      "name":  "Decodificar y Devolver Archivo",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       1100,
                                       80
                                   ]
                  }
