                  {
                      "parameters":  {
                                         "jsCode":  "/**\n * Guardar archivo binario recibido desde el formulario n8n\n * Compatibilidad con n8nâ€¯2.16 (binaryDataMode = \"filesystem\").\n */\nconst fs   = require(\u0027fs\u0027);\nconst path = require(\u0027path\u0027);\n\n// 1ï¸âƒ£ Obtener la clave del binario (se asume un solo archivo)\nconst binaryKey = Object.keys($binary)[0];\nif (!binaryKey) throw new Error(\u0027No se encontrÃ³ dato binario en el formulario.\u0027);\n\n// 2ï¸âƒ£ Obtener el objeto del archivo\nconst item = $binary[binaryKey];\n\n// 3ï¸âƒ£ Determinar origen del contenido\nlet sourcePath; // ruta en disco (filesystem)\nlet buffer;     // fallback base64\n\nif (item.filePath) {\n  // Modo filesystem\n  sourcePath = item.filePath;\n} else if (item.data) {\n  // Fallback: base64 dentro de `item.data`\n  buffer = Buffer.isBuffer(item.data)\n    ? item.data\n    : Buffer.from(item.data, \u0027base64\u0027);\n} else {\n  throw new Error(\u0027El objeto binario no contiene \"filePath\" ni \"data\".\u0027);\n}\n\n// 4ï¸âƒ£ Ruta temporal en /tmp\nconst tmpDir = \u0027/tmp\u0027;\nif (!fs.existsSync(tmpDir)) fs.mkdirSync(tmpDir, { recursive: true });\nconst tempPath = path.join(tmpDir, item.fileName);\n\n// 5ï¸âƒ£ Copiar o escribir el archivo\nif (sourcePath) {\n  fs.copyFileSync(sourcePath, tempPath);\n} else {\n  fs.writeFileSync(tempPath, buffer);\n}\n\n// 6ï¸âƒ£ Devolver datos para los siguientes nodos\nreturn {\n  filePath:    tempPath,\n  fileName:    item.fileName,\n  fuenteFinal: $json[\u0027Nombre de la Fuente\u0027] || item.fileName,\n};\n"
                                     },
