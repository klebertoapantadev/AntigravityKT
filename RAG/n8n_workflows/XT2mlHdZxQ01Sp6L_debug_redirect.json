                      "parameters":  {
                                         "jsCode":  "const items = $input.all();\n\nfor (let i = 0; i \u003c items.length; i++) {\n  const safeFilename = items[i].json.name.normalize(\u0027NFC\u0027).replace(/\\s+/g, \u0027_\u0027);\n  items[i].json.nombre_archivo_limpio = safeFilename;\n}\n\nreturn items;"
