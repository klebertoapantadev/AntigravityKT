                      "parameters":  {
                                         "jsCode":  "const fs = require(\u0027fs\u0027);\nconst items = $input.all();\nfor (let i = 0; i \u003c items.length; i++) {\n  try {\n    // Intentar obtener de binario primero\n    let buffer;\n    try {\n      buffer = await this.helpers.getBinaryDataBuffer(i, \u0027data\u0027);\n    } catch (e) {\n      // Si no hay binario, usar el body (si es texto)\n      const content = items[i].json.body || items[i].json.query.content;\n      buffer = Buffer.from(content);\n    }\n    \n    const filePath = \u0027/opt/RAG/implementacion_SARA/Ingesta_PDF_WEB.py\u0027;\n    fs.writeFileSync(filePath, buffer);\n    items[i].json.success = true;\n    items[i].json.size = buffer.length;\n  } catch (err) {\n    items[i].json.success = false;\n    items[i].json.error = err.message;\n  }\n}\nreturn items;"
